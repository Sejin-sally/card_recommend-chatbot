# =========================
# Data: keep folder structure only
# - data 아래 모든 파일은 무시
# - 단, 폴더 유지를 위한 .gitkeep만 추적
# =========================
data/**
!data/**/.gitkeep

# (추가 안전장치) 너가 말한 2개 유형은 확실히 차단
data/cache/*.json
data/cards/*.csv

